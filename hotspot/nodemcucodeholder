// NORMAL MODE — Coin slot + admin, server on port 8080
// ══════════════════════════════════════════════════════════════════════

void post_result() {
    if (WiFi.status() != WL_CONNECTED) return;
    HTTPClient http;
    String url = String("http://") + cfg.portal_ip + ":"
                 + cfg.portal_port + "/cgi-bin/coin_result.sh";
    http.begin(wifiClient, url);
    http.setTimeout(5000);
    http.addHeader("Content-Type", "application/x-www-form-urlencoded");
    if (http.POST(pendingBody) > 0) {
        if (http.getString().indexOf("\"ok\":true") >= 0) {
            pendingResult  = false;
            pendingBody    = "";
            pendingRetries = 0;
            // Portal has now definitively credited these coins — safe to drop
            // the crash-recovery mirror for this session.
            clearPersistedSessionIfMatches(pendingSid);
            pendingSid     = "";
        }
    }
    http.end();
}

// ── POWER-OUTAGE RECOVERY ──────────────────────────────────────────────────
// Called once right after connectWiFi() in startNormalMode(), and then again
// every RECOVERY_RETRY_MS from loop() for as long as the mirror file exists.
// The repeat calls matter because the ONT/router often hasn't finished
// booting yet when this device comes up after a shared power outage, so the
// very first attempt frequently finds WiFi not connected and simply returns.
// If a session mirror survived on flash, the previous run died mid-session —
// almost always a power cut that took the portal down too. We POST the
// preserved amount to the portal's coin_result.sh in RECOVERY mode: it
// carries the client MAC and is signed with it, so coin_result.sh can
// grant/extend that device's time even though its own /tmp session
// bookkeeping was wiped by the same outage. The mirror is cleared only after
// the portal confirms "ok" AND it still belongs to this SID, so a
// failed/limited reconnect just retries on the next pass instead of losing
// the coins.
void recoverSessionFromFlash() {
    if (!LittleFS.exists(SESSION_PATH_FS)) return;

    File f = LittleFS.open(SESSION_PATH_FS, "r");
    if (!f) return;
    String line = f.readStringUntil('\n');
    f.close();
    line.trim();
    if (line.length() == 0) { clearPersistedSession(); return; }

    // Parse "SID MAC PESOS"
    int s1 = line.indexOf(' ');
    int s2 = (s1 >= 0) ? line.indexOf(' ', s1 + 1) : -1;
    if (s1 < 0 || s2 < 0) { clearPersistedSession(); return; }
    String rSid = line.substring(0, s1);
    String rMac = line.substring(s1 + 1, s2);
    String rAmtS = line.substring(s2 + 1);
    rSid.trim(); rMac.trim(); rAmtS.trim();
    int rAmt = rAmtS.toInt();

    // Nothing was actually paid, or we never learned the MAC → nothing to
    // recover; just drop the stale mirror.
    if (rAmt <= 0 || rMac.length() == 0 || rMac == "-") {
        clearPersistedSession();
        return;
    }

    if (WiFi.status() != WL_CONNECTED) return;   // try again next boot

    // token = md5(PSK:SID:AMOUNT:MAC:recover)
    String plain = String(cfg.psk) + ":" + rSid + ":" + String(rAmt)
                   + ":" + rMac + ":recover";
    String body  = "sid=" + rSid + "&amount=" + String(rAmt)
                   + "&mac=" + rMac + "&recover=1&sig=" + md5_hex(plain);

    HTTPClient http;
    String url = String("http://") + cfg.portal_ip + ":"
                 + cfg.portal_port + "/cgi-bin/coin_result.sh";
    http.begin(wifiClient, url);
    http.setTimeout(5000);
    http.addHeader("Content-Type", "application/x-www-form-urlencoded");
    int code = http.POST(body);
    bool ok = (code > 0 && http.getString().indexOf("\"ok\":true") >= 0);
    http.end();

    // Only forget the coins once the portal has definitively credited them —
    // and only if the mirror still holds this session (a new session may have
    // already started and overwritten it while this POST was in flight).
    if (ok) clearPersistedSessionIfMatches(rSid);
}

void endSession() {
    setCoinAcceptor(false);         // block coins immediately
    sessionActive  = false;
    finalizing     = false;
    countdownPaused = false;
    sessionStartMs = 0;

    int finalAmount = coinPesos;
    coinPesos = 0;

    // NOTE: the flash mirror is deliberately NOT cleared here. It's only
    // cleared once post_result() gets a confirmed "ok" from the portal. If we
    // cleared it now, a power cut during the up-to-50s retry window below
    // would erase the only surviving record of these coins before the portal
    // ever actually saw them.
    pendingSid = activeSid;

    String plain = String(cfg.psk) + ":" + activeSid + ":"
                   + String(finalAmount) + ":end";
    pendingBody    = "sid=" + activeSid + "&amount="
                     + String(finalAmount) + "&sig=" + md5_hex(plain);
    pendingRetries = 0;
    pendingResult  = true;
    activeSid      = "";
    activeClientMac = "";
    lastSessionEndMs = millis();   // start the post-session grace clock for any queued reboot
    post_result();
}

// ── DEFERRED REBOOT SERVICE ────────────────────────────────────────
// Called every loop(). Decides WHEN to reboot, never interrupting a paying
// customer:
//   1. Queue a reboot if the daily interval elapsed, or if free heap has
//      been below the danger floor for HEAP_LOW_CONFIRM checks in a row.
//   2. Once queued, hold off while a coin session is active/finalizing
//      (someone is inserting coins), then wait POST_SESSION_WAIT_MS after it
//      ends and re-check — if a NEW session started in that minute, wait
//      again. Only reboot once the machine has been idle for the full grace
//      minute.
void serviceReboot() {
    static unsigned long bootMs      = millis();
    static unsigned long lastHeapChk = 0;
    static uint8_t       heapStrikes = 0;

    // 1a) Scheduled interval reached? (elapsed-subtraction is rollover-safe)
    if (!rebootPending && (millis() - bootMs) >= REBOOT_INTERVAL_MS) {
        rebootPending = true;
        rebootReason  = "scheduled";
    }

    // 1b) Heap watchdog — sample periodically, require consecutive low reads
    if (millis() - lastHeapChk >= HEAP_CHECK_MS) {
        lastHeapChk = millis();
        if (ESP.getFreeHeap() < HEAP_LOW_BYTES) {
            if (++heapStrikes >= HEAP_LOW_CONFIRM && !rebootPending) {
                rebootPending = true;
                rebootReason  = "low_heap";
            }
        } else {
            heapStrikes = 0;   // recovered — reset the strike counter
        }
    }

    if (!rebootPending) return;

    // 2) A reboot is queued — but never cut off a paying customer.
    if (sessionActive || finalizing) return;                          // coins being inserted → wait
    if ((millis() - lastSessionEndMs) < POST_SESSION_WAIT_MS) return; // grace minute not up, or a new session just started

    // Idle, grace minute elapsed, no new session → safe to reboot now.
    setCoinAcceptor(false);   // make sure the slot is blocked across the reboot
    delay(50);
    ESP.restart();
}

void handle_coin_start() {
    if (sessionActive && coinServer.arg("sid") == activeSid) {
        coinServer.send(200, "application/json", "{\"ok\":true,\"resumed\":true}");
        return;
    }
    if (sessionActive) {
        coinServer.send(409, "application/json", "{\"ok\":false,\"error\":\"busy\"}");
        return;
    }

    String sid = coinServer.arg("sid");
    String sig = coinServer.arg("sig");
    String to  = coinServer.arg("timeout");
    String mac = coinServer.arg("mac");   // paying client's MAC, for power-outage recovery

    if (sid.length() != 16) {
        coinServer.send(400, "application/json", "{\"ok\":false,\"error\":\"bad_sid\"}");
        return;
    }
    if (!sig_ok(sig, String(cfg.psk) + ":" + sid + ":start")) {
        coinServer.send(403, "application/json", "{\"ok\":false,\"error\":\"bad_sig\"}");
        return;
    }

sessionActive    = true;
    finalizing       = false;
    cancelRequested  = false;
    activeSid        = sid;
    activeClientMac  = mac;       // remembered so a recovery POST can rebuild the portal session
    coinPesos        = 0;
    coinDirty        = false;
    sessionStartMs   = millis();
    lastPulseMs      = millis(); // Init
    lastPollMs       = millis(); // the /start request itself counts as fresh contact
    countdownPaused  = false;
    
    sessionTimeoutMs = (to.length() > 0)
                       ? (unsigned long)to.toInt() * 1000UL
                       : (unsigned long)cfg.timeout_sec * 1000UL;
    setCoinAcceptor(true);
    persistSession();            // mirror the (zero-peso) session to flash immediately
    coinServer.send(200, "application/json", "{\"ok\":true}");
}

// Ends the session early on the user's signal ("Done" / "Cancel" in the UI).
// Does NOT call endSession() directly — see loop() for why.
void handle_coin_cancel() {
    String sid = coinServer.arg("sid");
    String sig = coinServer.arg("sig");

    // Already ended (timed out naturally just before this arrived, or a duplicate click)
    if (!sessionActive || sid != activeSid) {
        coinServer.send(200, "application/json", "{\"ok\":true,\"msg\":\"already_ended\"}");
        return;
    }
    if (!sig_ok(sig, String(cfg.psk) + ":" + sid + ":cancel")) {
        coinServer.send(403, "application/json", "{\"ok\":false,\"error\":\"bad_sig\"}");
        return;
    }

    // Just signal — loop() picks this up so it can wait for trailing coin pulses securely
    cancelRequested = true;
    coinServer.send(200, "application/json", "{\"ok\":true}");
}

void handle_coin_status() {
    String sid = coinServer.arg("sid");
    String sig = coinServer.arg("sig");

    if (sid != activeSid || !sessionActive) {
        coinServer.send(404, "application/json", "{\"ok\":false,\"amount\":0}");
        return;
    }
    if (!sig_ok(sig, String(cfg.psk) + ":" + sid + ":poll")) {
        coinServer.send(403, "application/json", "{\"ok\":false,\"error\":\"bad_sig\"}");
        return;
    }

    // A verified poll landed → the portal link is alive. Record it so the
    // link-loss watchdog in loop() knows the countdown may keep running, and
    // un-pause: while paused, loop() froze the window by advancing
    // sessionStartMs every tick, so simply clearing the flag resumes the
    // countdown exactly where it left off — no coin-insert time was consumed
    // while the portal was unreachable.
    lastPollMs = millis();
    countdownPaused = false;

    int amt = coinPesos;

    long remMs = (long)sessionTimeoutMs - (long)(millis() - sessionStartMs);
    if (remMs < 0) remMs = 0;
    int remaining = remMs / 1000;

    String sig2 = md5_hex(String(cfg.psk) + ":" + sid + ":" + String(amt) + ":status");
    coinServer.send(200, "application/json",
        "{\"ok\":true,\"amount\":" + String(amt) + ",\"remaining\":" + String(remaining) +
        ",\"sig\":\"" + sig2 + "\"}");
}

// Soft factory reset — only accepts requests from the portal IP
// Issues a fresh one-time nonce for the signed reset flow. Restricted to the
// portal IP so a random hotspot client can't farm nonces; the nonce is
// useless anyway without the PSK to sign it.
void handle_nonce() {
    String caller = coinServer.client().remoteIP().toString();
    if (caller != String(cfg.portal_ip)) {
        coinServer.send(403, "application/json", "{\"ok\":false,\"error\":\"forbidden\"}");
        return;
    }
    char buf[17];
    snprintf(buf, sizeof(buf), "%08x%08x",
             (unsigned)os_random(), (unsigned)os_random());
    resetNonce    = String(buf);
    nonceIssuedMs = millis();
    coinServer.send(200, "application/json",
        "{\"ok\":true,\"nonce\":\"" + resetNonce + "\"}");
}

void handle_admin_reset() {
    String caller = coinServer.client().remoteIP().toString();
    if (caller != String(cfg.portal_ip)) {
        coinServer.send(403, "application/json", "{\"ok\":false,\"error\":\"forbidden\"}");
        return;
    }
    // Require a fresh, single-use nonce signed with the PSK:
    //   token = md5(PSK:nonce:reset)   (matches coin.sh's reset flow)
    // The old code trusted the source IP alone (spoofable on the shared
    // hotspot LAN), making /reset an unauthenticated config-wipe DoS.
    if (resetNonce.length() == 0 || (millis() - nonceIssuedMs) > NONCE_TTL_MS) {
        coinServer.send(403, "application/json", "{\"ok\":false,\"error\":\"no_nonce\"}");
        return;
    }
    String token = coinServer.arg("token");
    bool good = sig_ok(token, String(cfg.psk) + ":" + resetNonce + ":reset");
    resetNonce = "";   // single-use: burn the nonce regardless of outcome
    if (!good) {
        coinServer.send(403, "application/json", "{\"ok\":false,\"error\":\"bad_token\"}");
        return;
    }
    coinServer.send(200, "application/json",
        "{\"ok\":true,\"msg\":\"wiped, rebooting into setup AP\"}");
    wipeConfig();
    delay(1000);
    ESP.restart();
}

// /setwifi — the portal (wlanbasic.cgi) hands us the NEW credentials for the
// SSID we ride on, right before it retunes that AP. We save them, ACK, and
// switch over a moment later (see wifiChangePending in loop) so this reply is
// delivered and the AP has time to come up on the new name first. Without this
// handshake, renaming the AP would silently strand the coin slot offline.
//
// Auth mirrors /reset: portal-IP only + a single-use, PSK-signed nonce that
// also binds the exact ssid+pass:  token = md5(PSK:nonce:ssid:pass:setwifi)
void handle_set_wifi() {
    String caller = coinServer.client().remoteIP().toString();
    if (caller != String(cfg.portal_ip)) {
        coinServer.send(403, "application/json", "{\"ok\":false,\"error\":\"forbidden\"}");
        return;
    }
    if (resetNonce.length() == 0 || (millis() - nonceIssuedMs) > NONCE_TTL_MS) {
        coinServer.send(403, "application/json", "{\"ok\":false,\"error\":\"no_nonce\"}");
        return;
    }
    String newSsid = coinServer.arg("ssid");
    String newPass = coinServer.arg("pass");
    String token   = coinServer.arg("token");
    bool good = sig_ok(token, String(cfg.psk) + ":" + resetNonce + ":" +
                              newSsid + ":" + newPass + ":setwifi");
    resetNonce = "";   // single-use: burn the nonce regardless of outcome
    if (!good) {
        coinServer.send(403, "application/json", "{\"ok\":false,\"error\":\"bad_token\"}");
        return;
    }
    if (newSsid.length() == 0 || newSsid.length() > 63) {
        coinServer.send(200, "application/json", "{\"ok\":false,\"error\":\"bad_ssid\"}");
        return;
    }
    if (newPass.length() > 63) {   // WPA-PSK max, and fits cfg.pass[64]
        coinServer.send(200, "application/json", "{\"ok\":false,\"error\":\"bad_pass\"}");
        return;
    }
    // Persist the new credentials now, but keep the current link up until we
    // ACK. The actual re-association is deferred to loop() so this response is
    // delivered and the portal can switch the AP over first.
    newSsid.toCharArray(cfg.ssid, sizeof(cfg.ssid));
    newPass.toCharArray(cfg.pass, sizeof(cfg.pass));
    bool saved = saveConfig();
    coinServer.send(200, "application/json",
        String("{\"ok\":") + (saved ? "true" : "false") +
        ",\"msg\":\"credentials accepted, switching shortly\"}");
    if (saved) {
        wifiChangePending = true;
        wifiChangeReqMs   = millis();   // apply after WIFI_CHANGE_DELAY_MS elapses
    }
}

// ── OTA SELF-UPDATE ──────────────────────────────────────────────────────────
// The portal (ota.sh) pushes a new firmware image to us as part of its own OTA,
// but ONLY when our FW_VERSION differs from the release. Auth + flow mirror the
// /reset and /setwifi endpoints exactly:
//
//   portal: GET /version                     → {"ok":true,"fw":"x.y.z"}   (gate)
//   portal: GET /nonce                        → fresh single-use nonce
//   portal: GET /update?md5=<hex>&token=<t>    t = md5(PSK:nonce:md5:update)
//
// On a valid signed request we pull the .bin from OUR OWN portal over the
// already-trusted hotspot LAN (cfg.portal_ip:cfg.portal_port, /firmware/
// coin_nodemcu.bin) — no TLS, no GitHub on the ESP — self-flash it with an
// ENFORCED MD5 check, and reboot. On ANY failure (bad token, short download,
// MD5 mismatch) the new image is never committed: Update leaves the running
// firmware active, so a corrupt or spoofed push cannot brick the coin slot.
//
// FLASH-LAYOUT REQUIREMENT: build with a size that reserves an OTA region,
// e.g. arduino-cli FQBN option ...:eesz=4M2M (4MB flash / 2MB FS) or the
// Arduino IDE "Flash Size: 4MB (FS:1MB OTA:~1019KB)". Without an OTA slot,
// Update.begin() will fail and the push is safely refused.

// Report running firmware version. Portal-IP only — no reason to let a random
// hotspot client fingerprint the coin slot's firmware.
void handle_version() {
    String caller = coinServer.client().remoteIP().toString();
    if (caller != String(cfg.portal_ip)) {
        coinServer.send(403, "application/json", "{\"ok\":false,\"error\":\"forbidden\"}");
        return;
    }
    coinServer.send(200, "application/json",
        String("{\"ok\":true,\"fw\":\"") + FW_VERSION + "\"}");
}

void handle_update() {
    String caller = coinServer.client().remoteIP().toString();
    if (caller != String(cfg.portal_ip)) {
        coinServer.send(403, "application/json", "{\"ok\":false,\"error\":\"forbidden\"}");
        return;
    }
    if (resetNonce.length() == 0 || (millis() - nonceIssuedMs) > NONCE_TTL_MS) {
        coinServer.send(403, "application/json", "{\"ok\":false,\"error\":\"no_nonce\"}");
        return;
    }
    String md5   = coinServer.arg("md5");
    String token = coinServer.arg("token");
    
    // Signed, single-use, and bound to the exact image we may flash:
    bool good = sig_ok(token, String(cfg.psk) + ":" + resetNonce + ":" + md5 + ":update");
    resetNonce = "";   // single-use: burn the nonce regardless of outcome
    if (!good) {
        coinServer.send(403, "application/json", "{\"ok\":false,\"error\":\"bad_token\"}");
        return;
    }
    md5.toLowerCase();
    if (md5.length() != 32) {
        coinServer.send(200, "application/json", "{\"ok\":false,\"error\":\"bad_md5\"}");
        return;
    }
    // Never interrupt a paying customer — the portal retries on its next run.
    if (sessionActive || finalizing) {
        coinServer.send(200, "application/json", "{\"ok\":false,\"error\":\"busy\"}");
        return;
    }
    
    // ACK first so the portal's wget gets a definitive reply before we spend
    // several seconds downloading + flashing (and then rebooting on success).
    coinServer.send(200, "application/json", "{\"ok\":true,\"msg\":\"updating, will reboot on success\"}");
    delay(50);                 // let the reply drain before we block on the download

    setCoinAcceptor(false);    // block coins while we flash

    // Pull from our own portal over the trusted hotspot LAN
    String url = String("http://") + cfg.portal_ip + ":" + cfg.portal_port + "/firmware/coin_nodemcu.bin";
    WiFiClient uc;
    HTTPClient http;
    
    // Force HTTP/1.0 to completely bypass chunked encoding issues
    http.useHTTP10(true); 

    if (!http.begin(uc, url)) {
        Serial.println("OTA: http.begin failed");
        return;
    }
    
    http.setTimeout(20000);
    int code = http.GET();
    Serial.printf("OTA HTTP %d\n", code);

    if (code != HTTP_CODE_OK) {
        http.end();
        return;
    }
    
    int len = http.getSize();
    Serial.printf("OTA size=%d\n", len);
    if (len <= 0) { http.end(); return; }

    if (!Update.begin((size_t)len)) {
        Serial.printf("Update.begin failed: %s\n", Update.getErrorString());
        http.end();
        return;
    }
    
    Update.setMD5(md5.c_str()); // Enforce integrity

    // ── NEW ROBUST CHUNK LOOP ──
    WiFiClient* stream = http.getStreamPtr();
    uint8_t buff[512]; // Tiny buffer to easily handle slower network packets
    size_t written = 0;
    unsigned long lastDataTime = millis();

    Serial.println("Starting manual chunk write...");

    while (http.connected() && written < (size_t)len) {
        size_t available_bytes = stream->available();
        
        if (available_bytes > 0) {
            int bytesRead = stream->readBytes(buff, min(available_bytes, sizeof(buff)));
            if (bytesRead > 0) {
                Update.write(buff, bytesRead);
                written += bytesRead;
                lastDataTime = millis(); // Reset stream timer
            }
        } else {
            delay(10); // Pause briefly to let the router buffer catch up
            if (millis() - lastDataTime > 7000) { // 7 second network drop timeout
                Serial.println("\nOTA Error: Stream went dry.");
                break;
            }
        }
    }

    Serial.printf("Written %u/%d\n", written, len);
    http.end();

    if (written == (size_t)len) {
        if (Update.end()) {
            Serial.println("OTA Success! Rebooting into new firmware...");
            delay(200);
            ESP.restart(); // Boot into the new image
        } else {
            Serial.printf("Update.end failed: %s\n", Update.getErrorString());
        }
    } else {
        Serial.println("Update aborted: File size mismatch.");
        Update.end(); 
    }
}


bool connectWiFi() {
    WiFi.persistent(false);        // don't rewrite creds to flash every boot (wear)
    WiFi.mode(WIFI_STA);
    WiFi.setAutoReconnect(false);  // we manage reconnects manually; avoids DHCP races
    WiFi.begin(cfg.ssid, cfg.pass);

    // The ONT's hotspot AP can take 90-180s to come up at cold boot — far
    // longer than this device. Wait patiently (up to ~150s) so we don't give
    // up before the SSID is even broadcasting. yield()/delay() keeps the WiFi
    // stack and watchdog fed during the wait.
    const unsigned long TIMEOUT_MS = 150000UL;
    unsigned long start = millis();
    while (WiFi.status() != WL_CONNECTED && (millis() - start) < TIMEOUT_MS) {
        delay(250);
        yield();
    }

    if (WiFi.status() != WL_CONNECTED) return false;

    // WLAN may still be bridged to br0 (192.168.8.1) when we first associate —
    // the hotspot daemon can take tens of seconds to move WLAN to br1 (portal IP).
    // On each mismatch: disconnect, wait 5s, then call begin() (not reconnect())
    // to force a clean DHCP DISCOVER; reconnect() can reuse the old br0 lease
    // and return the wrong gateway even after br1 has taken over.
    const unsigned long GW_WAIT_MS = 60000UL;
    unsigned long gwStart = millis();
    while (WiFi.gatewayIP().toString() != String(cfg.portal_ip)) {
        if (millis() - gwStart >= GW_WAIT_MS) {
            WiFi.disconnect();
            return false;   // br1 didn't bind in time; loop() watchdog will keep retrying
        }
        WiFi.disconnect();
        delay(5000);
        yield();
        WiFi.begin(cfg.ssid, cfg.pass);
        unsigned long rStart = millis();
        while (WiFi.status() != WL_CONNECTED && (millis() - rStart) < 15000UL) {
            delay(250);
            yield();
        }
        if (WiFi.status() != WL_CONNECTED) return false;
    }

    return true;
}

void startNormalMode() {
    isSetupMode = false;

    // Best-effort connect. CRITICAL: never wipeConfig() on failure here. At
    // cold boot the ONT hotspot AP may simply not be up yet, and erasing the
    // saved credentials is what made the device "reset itself" into setup mode
    // during ONT boot. Instead we always start the coin server and let the
    // loop() watchdog + SDK auto-reconnect keep trying until the AP appears.
    // Genuinely-wrong credentials are recovered via the D1 factory-reset button
    // or the signed /reset endpoint — not by self-wiping on a transient miss.
    connectWiFi();

    // If a coin session was mirrored to flash and never cleared, the last run
    // died mid-session (power cut). Push the preserved coins to the portal now
    // so the customer still gets the time they paid for.
    recoverSessionFromFlash();

    coinServer.on("/start",   handle_coin_start);
    coinServer.on("/status",  handle_coin_status);
    coinServer.on("/cancel",  handle_coin_cancel);
    coinServer.on("/nonce",   handle_nonce);
    coinServer.on("/reset",   handle_admin_reset);
    coinServer.on("/setwifi", handle_set_wifi);
    coinServer.on("/version", handle_version);
    coinServer.on("/update",  handle_update);
    coinServer.begin();
}


// ══════════════════════════════════════════════════════════════════════
// ARDUINO SETUP & LOOP
// ══════════════════════════════════════════════════════════════════════

void setup() {
        pinMode(D0, INPUT_PULLUP);
    pinMode(D2, INPUT_PULLUP);
    pinMode(D3, INPUT_PULLUP); // Has on-board 10k pullup, but software pullup adds stability
    pinMode(D4, INPUT_PULLUP); // Has on-board LED, safe to pull up
    pinMode(D5, INPUT_PULLUP);
    pinMode(COIN_PIN,        INPUT_PULLUP);
    pinMode(COIN_ENABLE_PIN, OUTPUT);
    setCoinAcceptor(false);   // block coins on boot until a session starts

    // ── Factory reset via D1 button held 3s ─────────────────────────
    // Wire a momentary button between D1 (GPIO5) and GND.
    // Hold during power-on → wipes /cfg.txt → reboots into setup AP.
    pinMode(RESET_PIN, INPUT_PULLUP);
    if (digitalRead(RESET_PIN) == LOW) {
        unsigned long held = millis();
        while (digitalRead(RESET_PIN) == LOW) {
            if (millis() - held > 3000) {
                if (LittleFS.begin()) wipeConfig();
                delay(200);
                ESP.restart();
            }
        }
        // Released before 3s — normal boot, don't reset
    }

    attachInterrupt(digitalPinToInterrupt(COIN_PIN), onCoinPulse, CHANGE);

    setConfigDefaults();

    if (!LittleFS.begin()) {
        // Filesystem mount failed — can't save config, go to setup mode
        // (setup page will show save error; owner should check partition table)
        startSetupMode();
        return;
    }

    if (loadConfig()) {
        startNormalMode();
    } else {
        startSetupMode();
    }
}

void loop() {
    if (isSetupMode) {
        setupServer.handleClient();
        return;
    }

    coinServer.handleClient();

    // Deferred Wi-Fi credential switch requested via /setwifi. Applied a moment
    // after we ACK so the HTTP reply drains and the portal has time to retune
    // the AP onto the new SSID before we drop the old association. The 15s
    // watchdog further below then keeps retrying until the new AP appears.
    // Elapsed-subtraction compare so it stays correct across millis() rollover.
    if (wifiChangePending && (millis() - wifiChangeReqMs) >= WIFI_CHANGE_DELAY_MS) {
        wifiChangePending = false;
        WiFi.disconnect();
        delay(100);
        WiFi.begin(cfg.ssid, cfg.pass);   // new creds already saved to cfg
    }

// --- ANTI-SPARK / EMI HEALING ---
    // Continuously re-assert the coin slot enable pin during an active session.
    // If a piezo spark scrambles the ESP8266's GPIO registers and turns D7 into 
    // an INPUT, this forces it back to an OUTPUT almost instantly.
// --- ANTI-SPARK / EMI HEALING ---
    // FIX: Throttle to once per second. Calling pinMode disables interrupts
    // continuously and can cause the ESP to miss coin pulses!
    static unsigned long lastHealMs = 0;
    if (sessionActive && !finalizing && (millis() - lastHealMs > 1000)) {
        lastHealMs = millis();
        pinMode(COIN_ENABLE_PIN, OUTPUT);
        digitalWrite(COIN_ENABLE_PIN, COIN_ENABLE_ACTIVE);
    }    // --- CRASH-SAFE COIN MIRROR ---
    // A coin was counted since we last checked → flush the new running total to
    // flash so a power cut in the next instant can't erase it. Done here in
    // loop() (not the ISR) because LittleFS writes must not run inside an
    // interrupt. The flag is cleared before the write so a coin landing during
    // the write is caught on the following pass.
// --- CRASH-SAFE COIN MIRROR ---
    // FIX: Wait 300ms after the last pulse before saving to flash. 
    // This prevents locking up the CPU while a multi-pulse coin is still actively sending pulses.
    if (sessionActive && coinDirty && (millis() - lastPulseMs > 300)) {
        coinDirty = false;
        persistSession();
    }

    // --- LINK-LOSS COUNTDOWN PAUSE ---
    // While a session is open the portal polls /status ~1/s. If those polls go
    // silent the portal/link is down; freeze the coin-insert countdown so the
    // customer doesn't lose their window (and already-inserted coins) to a
    // dropout. We freeze by advancing sessionStartMs in lock-step with millis()
    // every tick, so "elapsed" stops growing. A verified poll clears
    // countdownPaused (see handle_coin_status) and the window resumes intact.
    // Coins may still be inserted while paused (the ISR still counts them and
    // extends the window). If the outage drags on past MAX_PAUSE_MS we stop
    // waiting and finalize, converting the inserted coins into time so they are
    // never stuck.
    {
        unsigned long nowMs = millis();
        if (sessionActive && !finalizing) {
            bool linkStale = (nowMs - lastPollMs) > LINK_STALE_MS;
            if (linkStale && !countdownPaused) {
                countdownPaused = true;
                pauseStartMs = nowMs;
            }
            if (countdownPaused) {
                // Keep the window frozen: consume the delta so elapsed is flat.
                if (lastLoopMs != 0) sessionStartMs += (nowMs - lastLoopMs);
                // Safety valve: don't pause forever. Finalize (grant the coins
                // as time) after MAX_PAUSE_MS of continuous silence.
                if ((nowMs - pauseStartMs) >= MAX_PAUSE_MS) {
                    countdownPaused = false;
                    finalizing = true;
                    setCoinAcceptor(false);
                }
            }
        }
        lastLoopMs = nowMs;
    }

    // PHASE 1: Initiate shutdown (user clicked Done/Cancel OR time ran out naturally)
    if (sessionActive && !finalizing && (cancelRequested || (millis() - sessionStartMs) >= sessionTimeoutMs)) {
        finalizing = true;
        setCoinAcceptor(false); // Instantly block new physical coins from entering the slot
    }

    // PHASE 2: Wait for any currently-dropping coin to finish its pulses
    if (sessionActive && finalizing) {
        // 500ms of absolute silence means the coin has completely passed the sensor
        if (millis() - lastPulseMs > 500) {
            cancelRequested = false;
            finalizing = false;
            endSession(); // Shuts down session natively and posts the full correct amount
        }
    }

    // Retry pending result POST after WiFi recovery (up to 10 attempts, 5s apart)
    if (pendingResult && pendingRetries < 10) {
        static unsigned long lastRetry = 0;
        if (millis() - lastRetry > 5000) {
            lastRetry = millis();
            pendingRetries++;
            post_result();
        }
    }

    // Retry the boot-time power-outage recovery POST until the portal
    // confirms it. A single attempt right after connectWiFi() in
    // startNormalMode() isn't enough: if the ONT/router hasn't finished
    // booting yet (common right after a shared power outage), that first
    // attempt fails and — without this — would never be retried until the
    // NEXT full reboot, leaving a customer's coins uncredited for hours.
    // recoverSessionFromFlash() is already a cheap no-op once nothing is left
    // to recover or WiFi still isn't connected, so just nudge it every 10s.
// Retry the boot-time power-outage recovery POST until the portal confirms it.
    // FIX: Only run if there is NO active session and no pending session ending.
    if (!sessionActive && !pendingResult && LittleFS.exists(SESSION_PATH_FS) && (millis() - lastRecoveryAttemptMs) >= RECOVERY_RETRY_MS) {
        lastRecoveryAttemptMs = millis();
        recoverSessionFromFlash();
    }
    // WiFi watchdog — reconnect check every 15s.
    // wrongGwStrikes: tolerate up to 3 consecutive wrong-gateway readings (45s)
    // before forcing re-DHCP, so a slow br0→br1 bridge transition doesn't cause
    // a tight disconnect/reconnect storm that prevents the correct lease arriving.
    static unsigned long lastWifiCheck = 0;
    static uint8_t wrongGwStrikes = 0;
    if (millis() - lastWifiCheck > 15000) {
        lastWifiCheck = millis();

        if (WiFi.status() != WL_CONNECTED) {
            wrongGwStrikes = 0;
            WiFi.begin(cfg.ssid, cfg.pass);   // full begin → clean DHCP DISCOVER
        }
        else if (WiFi.gatewayIP().toString() != String(cfg.portal_ip)) {
            // Wrong gateway (WLAN still on br0, or rogue DHCP).
            // Give br1 time to bind before forcing re-DHCP.
            if (++wrongGwStrikes >= 3) {
                wrongGwStrikes = 0;
                WiFi.disconnect();
                delay(1000);
                WiFi.begin(cfg.ssid, cfg.pass);  // reconnect immediately, don't wait for next cycle
            }
        }
        else {
            wrongGwStrikes = 0;                  // correct gateway — all good
        }
    }

    // Scheduled daily reboot + heap watchdog. Defers the actual restart until
    // the machine is idle so an active coin session is never interrupted.
    serviceReboot();

    delay(10);
}
