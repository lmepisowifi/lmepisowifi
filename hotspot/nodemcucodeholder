void handle_scan() {
    // Must be in AP+STA mode for scanning to work while AP is active
    int n = WiFi.scanNetworks();
    String j = "[";
    for (int i = 0; i < n; i++) {
        if (i) j += ",";
        j += "{\"ssid\":\"" + jsonEscape(WiFi.SSID(i)) + "\","
             "\"rssi\":"    + String(WiFi.RSSI(i)) + ","
             "\"enc\":"     + (WiFi.encryptionType(i) == ENC_TYPE_NONE ? "false" : "true") + "}";
    }
    j += "]";
    setupServer.send(200, "application/json", j);
}

void handle_save() {
    String ssid    = setupServer.arg("ssid");
    String pass    = setupServer.arg("pass");
    String psk     = setupServer.arg("psk");
    String ip      = setupServer.arg("ip");
    String port    = setupServer.arg("port");
    String coinval = setupServer.arg("coinval");
    String timeout = setupServer.arg("timeout");

    if (ssid.length() == 0 || ssid.length() > 63) {
        setupServer.send(200, "application/json", "{\"ok\":false,\"error\":\"Invalid SSID\"}");
        return;
    }
    if (psk.length() == 0 || psk.length() > 127) {
        setupServer.send(200, "application/json", "{\"ok\":false,\"error\":\"PSK required (max 127 chars)\"}");
        return;
    }
    if (ip.length() == 0) ip = DEFAULT_PORTAL_IP;

    ssid.toCharArray(cfg.ssid,      sizeof(cfg.ssid));
    pass.toCharArray(cfg.pass,      sizeof(cfg.pass));
    psk.toCharArray(cfg.psk,        sizeof(cfg.psk));
    ip.toCharArray(cfg.portal_ip,   sizeof(cfg.portal_ip));
    cfg.portal_port = port.toInt()    > 0 ? (uint16_t)port.toInt()    : DEFAULT_PORTAL_PORT;
    cfg.coin_value  = coinval.toInt() > 0 ? (uint8_t)coinval.toInt()  : DEFAULT_COIN_VALUE;
    cfg.timeout_sec = timeout.toInt() > 0 ? (uint8_t)timeout.toInt()  : DEFAULT_TIMEOUT;

    if (saveConfig()) {
        setupServer.send(200, "application/json", "{\"ok\":true}");
        delay(1500);
        ESP.restart();
    } else {
        setupServer.send(200, "application/json",
            "{\"ok\":false,\"error\":\"LittleFS write failed — check partition table\"}");
    }
}

void startSetupMode() {
    isSetupMode = true;
    // AP+STA so we can scan WiFi networks while hosting the AP
    WiFi.mode(WIFI_AP_STA);
    WiFi.softAP(AP_SSID);  // open — no password

    setupServer.on("/",     HTTP_GET,  serve_setup_page);
    setupServer.on("/scan", HTTP_GET,  handle_scan);
    setupServer.on("/save", HTTP_POST, handle_save);
    // Redirect everything else to the setup page
    setupServer.onNotFound([]() {
        setupServer.sendHeader("Location", "/", true);
        setupServer.send(302, "text/plain", "");
    });
    setupServer.begin();
}


