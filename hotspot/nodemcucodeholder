// ── COIN SESSION STATE ────────────────────────────────────────────────
volatile int           coinPesos        = 0;
bool                   sessionActive    = false;
volatile bool          finalizing       = false;  // True when waiting for pulses to settle
String                 activeSid        = "";
String                 activeClientMac  = "";      // MAC of the paying client (from portal /start)
volatile unsigned long sessionStartMs   = 0;      
unsigned long          sessionTimeoutMs = 30000UL;
volatile bool          cancelRequested  = false;  
volatile bool          coinDirty        = false;   // set by ISR when a coin was counted → loop persists it

// For anti-tamper / pulse limiting
volatile unsigned long lastPulseMs      = 0;

// ── LINK-LOSS COUNTDOWN PAUSE ─────────────────────────────────────────
// The portal polls /status roughly once a second while its Insert-Coin modal
// is open. If those polls stop arriving (portal rebooted, Wi-Fi dropped, or the
// whole unit briefly lost the AP) we must NOT keep burning the customer's
// coin-insert window — the coins they already dropped would silently time out
// and be lost. Instead we FREEZE the countdown while the link is stale and
// resume it the instant polls come back, so a reconnect continues exactly where
// it paused. Coins can still be inserted during the pause (each still resets the
// window) and the customer can still hit Done/Cancel once the portal reconnects.
volatile unsigned long lastPollMs       = 0;       // millis() of the last /status poll from the portal
unsigned long          lastLoopMs       = 0;       // for freezing sessionStartMs while paused
bool                   countdownPaused  = false;
unsigned long          pauseStartMs     = 0;
const unsigned long    LINK_STALE_MS    = 4000UL;          // no poll for 4s → treat link as stale, pause
const unsigned long    MAX_PAUSE_MS     = 5UL*60UL*1000UL; // after 5 min stalled, finalize so coins convert to time

// ── CRASH / POWER-OUTAGE COIN PRESERVATION ────────────────────────────
// A Piso-Wifi unit and its coin slot usually share one power brick, so a power
// outage kills both mid-session. Coins counted so far live only in RAM
// (coinPesos), so without help they vanish on the blackout. We therefore mirror
// the live session (sid + client MAC + running peso total) to LittleFS every
// time the total changes. On the next boot we read it back and POST a signed
// "recovery" result to the portal, which grants the customer the time they paid
// for — even though the portal's own /tmp bookkeeping was wiped by the same
// outage (coin_result.sh rebuilds it from the MAC we send).
#define SESSION_PATH_FS   "/coin_session.txt"

// Piezo igniter ("BBQ lighter") fraud: a spark touched to the pulse wire
// induces a clean FALLING edge that looks identical to a real coin pulse to
// an edge-only debounce — so it walked straight through the old gap<15 check.
// Genuine coin-acceptor optos pull the line LOW for the full mechanical/optical
// transit time of the coin (tens of ms); a piezo discharge is a near-instant
// transient, just a spike. Measuring how long the line actually stays LOW lets
// us reject the spike while still counting real coins.
// Calibrate MIN by logging real pulse widths from your acceptor (Serial.println
// the width in onCoinPulse during testing) — different acceptor models vary.
const unsigned long PULSE_MIN_WIDTH_US = 8000UL;    // reject anything shorter (spike)
const unsigned long PULSE_MAX_WIDTH_US = 200000UL;  // reject anything longer (stuck/noise)
volatile unsigned long pulseFallUs     = 0;
volatile bool          pulseInProgress = false;
// --- NEW VARIABLES FOR AUTO-DETECT ---
volatile unsigned long lastEdgeMs = 0;
volatile int           activeState = LOW; // Assumes NO by default
bool   pendingResult  = false;
String pendingBody    = "";
String pendingSid     = "";   // SID pendingBody belongs to — only clear that
                               // session's flash mirror once the portal confirms it
int    pendingRetries = 0;

// Boot-time power-outage recovery must be retried periodically, not attempted
// only once — see the recovery-retry block in loop().
unsigned long lastRecoveryAttemptMs = 0;
const unsigned long RECOVERY_RETRY_MS = 10000UL;

// One-time, short-lived nonce backing the signed /reset flow (see coin.sh).
String        resetNonce    = "";
unsigned long nonceIssuedMs = 0;
const unsigned long NONCE_TTL_MS = 30000UL;   // a fetched nonce is valid 30s

// Deferred Wi-Fi credential switch requested via /setwifi. We ACK the portal
// first, then re-associate ~1.5s later so the HTTP reply drains and the portal
// has time to retune the AP onto the new SSID before we drop the old link.
bool          wifiChangePending = false;
unsigned long wifiChangeReqMs   = 0;      // millis() when /setwifi was accepted
const unsigned long WIFI_CHANGE_DELAY_MS = 1500UL;

// ── AUTO-REBOOT + HEAP WATCHDOG ───────────────────────────────────�������
// Why reboot at all: this firmware leans hard on Arduino String
// concatenation (every coin pulse, /status poll and result POST builds
// throwaway Strings) plus HTTPClient, which fragments the ESP8266's small
// heap over time. Left running for weeks the largest free block shrinks
// until an allocation fails and the device locks up mid-session. A short,
// scheduled reboot during an idle moment resets the heap to a clean state.
//
// 1 day vs 3 days: 1 day is the safer pick here *because* of that heavy
// String/HTTPClient churn — a 24h cycle keeps fragmentation from ever
// building up, and the reboot only ever happens while the machine is idle
// (see serviceReboot() below), so customers never notice it. Bump this to
// 3UL * 24UL if your unit stays healthy longer and you'd rather reboot less.
const unsigned long REBOOT_INTERVAL_MS   = 24UL * 60UL * 60UL * 1000UL; // 1 day
const unsigned long POST_SESSION_WAIT_MS = 60UL * 1000UL;              // extra grace minute after a session ends

// Heap safety net: if free heap sits below HEAP_LOW_BYTES for
// HEAP_LOW_CONFIRM consecutive samples, queue a reboot. Consecutive-sample
// confirmation stops a momentary dip (e.g. during a TLS/HTTP POST) from
// triggering a needless reboot.
const unsigned long HEAP_LOW_BYTES   = 8000UL;   // ~8 KB danger floor
const unsigned long HEAP_CHECK_MS    = 10000UL;  // sample free heap every 10s
const uint8_t       HEAP_LOW_CONFIRM = 3;        // 3 low reads in a row (~30s) → reboot

// Set true once a reboot is queued (by the schedule or the heap watchdog).
// The actual ESP.restart() is deferred until the machine is idle — see
// serviceReboot() in loop(). rebootReason is kept for optional debugging.
bool          rebootPending    = false;
const char*   rebootReason     = "";
unsigned long lastSessionEndMs = 0;       // millis() when the last coin session ended


// ══════════════════════════════════════════════════════════════════════
// UTILITIES
// ══════════════════════════════════════════════════════════════════════

String md5_hex(const String& s) {
    MD5Builder b;
    b.begin();
    b.add((uint8_t*)s.c_str(), s.length());
    b.calculate();
    return b.toString();
}

// Constant-time signature compare — avoids leaking the expected MAC byte by
// byte via response-timing differences (String '==' early-exits on first
// mismatch). Cheap and behaviour-preserving for valid signatures.
bool sig_ok(const String& sig, const String& plain) {
    String expected = md5_hex(plain);
    if (sig.length() != expected.length()) return false;
    uint8_t diff = 0;
    for (size_t i = 0; i < expected.length(); i++)
        diff |= (uint8_t)sig[i] ^ (uint8_t)expected[i];
    return diff == 0;
}

void setCoinAcceptor(bool en) {
    // Re-initialize the pin mode every time, in case a spark reset it
    pinMode(COIN_ENABLE_PIN, OUTPUT);
    digitalWrite(COIN_ENABLE_PIN, en ? COIN_ENABLE_ACTIVE : !COIN_ENABLE_ACTIVE);
}

void IRAM_ATTR onCoinPulse() {
    unsigned long nowUs = micros();
    unsigned long nowMs = millis();
    int currentState = digitalRead(COIN_PIN);

    // ── AUTO-DETECT NO vs NC ─────────────────────────────────────────
    // If the line has been quiet for > 500ms, this edge MUST be 
    // the start of a new coin pulse. We lock in whatever state 
    // it just transitioned TO as the "active" pulse state.
    if (nowMs - lastEdgeMs > 500) {
        activeState = currentState;
        pulseInProgress = false; // Reset in case of prior glitches
    }
    lastEdgeMs = nowMs;

    if (currentState == activeState) {
        // Leading edge: Pulse started. Record it and wait for it to end.
        pulseFallUs = nowUs;
        pulseInProgress = true;
        return;
    }

    // Trailing edge: Pulse ended (returned to resting state).
    if (!pulseInProgress) return;
    pulseInProgress = false;

    // Check pulse width to reject piezo sparks (<8ms) or stuck sensors (>200ms)
    unsigned long widthUs = nowUs - pulseFallUs;
    if (widthUs < PULSE_MIN_WIDTH_US || widthUs > PULSE_MAX_WIDTH_US) return;

    if (sessionActive) {
        // Hardware debounce: ignore physically impossible fast pulses (<15ms).
        unsigned long gap = nowMs - lastPulseMs;
        if (gap < 15) return;

        lastPulseMs    = nowMs;
        coinPesos     += cfg.coin_value;
        sessionStartMs = nowMs;   // each valid coin extends the timeout window
        coinDirty      = true;    // loop() will mirror the new total to flash
    }
}

// JSON-safe escape (SSIDs can contain quotes/backslashes)
String jsonEscape(const String& s) {
    String r;
    r.reserve(s.length());
    for (char c : s) {
        if      (c == '"')  r += "\\\"";
        else if (c == '\\') r += "\\\\";
        else if (c == '\n') r += "\\n";
        else if (c == '\r') r += "\\r";
        else                r += c;
    }
    return r;
}


// ══════════════════════════════════════════════════════════════════════
// CONFIG STORAGE — LittleFS, KEY=VALUE lines
// ══════════════════════════════════════════════════════════════════════

void setConfigDefaults() {
    strncpy(cfg.ssid,      "",                 sizeof(cfg.ssid));
    strncpy(cfg.pass,      "",                 sizeof(cfg.pass));
    strncpy(cfg.psk,       DEFAULT_PSK,        sizeof(cfg.psk));
    strncpy(cfg.portal_ip, DEFAULT_PORTAL_IP,  sizeof(cfg.portal_ip));
    cfg.portal_port = DEFAULT_PORTAL_PORT;
    cfg.coin_value  = DEFAULT_COIN_VALUE;
    cfg.timeout_sec = DEFAULT_TIMEOUT;
}

// Returns true only if config exists and has a valid SSID
bool loadConfig() {
    if (!LittleFS.exists(CONFIG_PATH)) return false;
    File f = LittleFS.open(CONFIG_PATH, "r");
    if (!f) return false;

    while (f.available()) {
        String line = f.readStringUntil('\n');
        line.trim();
        int eq = line.indexOf('=');
        if (eq < 1) continue;
        String k = line.substring(0, eq);
        String v = line.substring(eq + 1);

        if      (k == "SSID")    v.toCharArray(cfg.ssid,      sizeof(cfg.ssid));
        else if (k == "PASS")    v.toCharArray(cfg.pass,      sizeof(cfg.pass));
        else if (k == "PSK")     v.toCharArray(cfg.psk,       sizeof(cfg.psk));
        else if (k == "IP")      v.toCharArray(cfg.portal_ip, sizeof(cfg.portal_ip));
        else if (k == "PORT")    cfg.portal_port = (uint16_t)v.toInt();
        else if (k == "COINVAL") cfg.coin_value  = (uint8_t)v.toInt();
        else if (k == "TIMEOUT") cfg.timeout_sec = (uint8_t)v.toInt();
    }
    f.close();
    return strlen(cfg.ssid) > 0;
}

bool saveConfig() {
    File f = LittleFS.open(CONFIG_PATH, "w");
    if (!f) return false;
    f.println("SSID="    + String(cfg.ssid));
    f.println("PASS="    + String(cfg.pass));
    f.println("PSK="     + String(cfg.psk));
    f.println("IP="      + String(cfg.portal_ip));
    f.println("PORT="    + String(cfg.portal_port));
    f.println("COINVAL=" + String(cfg.coin_value));
    f.println("TIMEOUT=" + String(cfg.timeout_sec));
    f.close();
    return true;
}

void wipeConfig() {
    LittleFS.remove(CONFIG_PATH);
}


// ══════════════════════════════════════════════════════════════════��═��═
// LIVE-SESSION MIRROR — LittleFS, survives power loss
// ══════════════════════════════════════════════════════════════════════
// One line: SID CLIENT_MAC PESOS
// Written every time the peso total changes during an active session, cleared
// once the session finalizes cleanly (endSession) or is recovered on boot.

void persistSession() {
    // Snapshot the volatile total once so an ISR mid-write can't tear it.
    int amt = coinPesos;
    File f = LittleFS.open(SESSION_PATH_FS, "w");
    if (!f) return;
    f.print(activeSid);
    f.print(' ');
    f.print(activeClientMac.length() ? activeClientMac : String("-"));
    f.print(' ');
    f.println(amt);
    f.close();
}

void clearPersistedSession() {
    LittleFS.remove(SESSION_PATH_FS);
}

// Only clears the mirror if it still belongs to the given SID. Needed because
// a new session can legitimately start (and overwrite the mirror with its own
// zero-peso entry) before a *previous* session's delayed/retried result POST
// finally gets confirmed — a blind clear at that point would wipe the new,
// still-live session's crash protection instead of the old one's.
void clearPersistedSessionIfMatches(const String &sid) {
    if (sid.length() == 0 || !LittleFS.exists(SESSION_PATH_FS)) return;
    File f = LittleFS.open(SESSION_PATH_FS, "r");
    if (!f) return;
    String line = f.readStringUntil('\n');
    f.close();
    int sp = line.indexOf(' ');
    String fileSid = (sp >= 0) ? line.substring(0, sp) : line;
    fileSid.trim();
    if (fileSid == sid) clearPersistedSession();
}

