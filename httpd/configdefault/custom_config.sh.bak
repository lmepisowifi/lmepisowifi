#!/bin/sh
flash set PON_MODE_AUTO_CHECK_ENABLE 1
flash set PON_MODE 1
flash set PON_VENDOR_ID xPON
flash set EPON_ONU_MODEL 081E
flash set EPON_EXTONU_MODEL M2-2050-G40
flash set GPON_ONU_MODEL M2-2050-G40
flash set HW_HWVER Ver.B
flash set PORT_REMAPPING 00,01,02,03,08,00,00,00,00,00
flash set SYS_CAPABILITY 0,2,0,0,1,1
flash set HW_CWMP_MANUFACTURER YOTC
flash set HW_CWMP_PRODUCTCLASS M2-2050-G40
flash set SNMP_SYS_NAME M2-2050-G40
flash set HW_WLAN0_REG_DOMAIN 1
flash set HW_WLAN1_REG_DOMAIN 1
flash set HW_WLAN0_COUNTRYSTR US
flash set HW_WLAN1_COUNTRYSTR US
flash set BIND_HGU_AS_SFU 1
mib set DEVICE_TYPE 1
mib set SW_PORT_TBL.0.Enable 1
mib set SW_PORT_TBL.1.Enable 1
mib set SW_PORT_TBL.2.Enable 1
mib set SW_PORT_TBL.3.Enable 1
mib set WLAN_MBSSIB_TBL.0.wlanDisabled 0
the