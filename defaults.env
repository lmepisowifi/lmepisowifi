# ============================================================
# defaults.env — canonical default values for tunable globals
# ============================================================
# This file is SHIPPED and REPLACED by every OTA release (it is a
# tracked component in ota.sh). It is the single source of truth for
# default values of user-settable globals.
#
# On boot, lmehspt.sh:
#   1. sources this file (defaults),
#   2. seeds any keys here that are MISSING from globals.env into
#      globals.env (see seed_globals()),
#   3. sources globals.env, whose values override these defaults.
#
# So when an OTA adds a NEW tunable here, existing devices automatically
# gain the key in their (preserved) globals.env with the default value,
# and it shows up pre-filled in the admin UI. Never put runtime-only file
# paths or secrets that shouldn't persist in globals.env here.
# ============================================================

# ── Network / portal ──────────────────────────────────────
PORTAL_IP="10.0.0.1"
PORTAL_PORT="80"
WWW2_PORT="8080"
WAN_INT="br0"
BR0_GATEWAY="192.168.18.1"

# ── Rate limiting ─────────────────────────────────────────
GLOBAL_RATE="50mbit"
PER_USER_RATE="5mbit"
PER_USER_BURST="10k"
UNAUTH_RATE="1000kbit"
INACTIVITY_TIMEOUT="300"

# ── Feature toggles ───────────────────────────────────────
HOTSPOT_ENABLED="1"
ANTI_TETHER="1"
COIN_ENABLED="1"

# ── Coin acceptor / NodeMCU ───────────────────────────────
NODEMCU_IP="10.0.0.2"
NODEMCU_MAC="e868e7c81814"
NODEMCU_PORT="8080"
COIN_PSK="lmepisowifi"
COIN_TIMEOUT="30"
COIN_RATES="1:15 5:90 10:210 15:360 20:720 25:1080 30:2160 35:2880 40:3600 45:4320 50:5040 55:5760"
COIN_STRIKE_THRESHOLD="3"
COIN_COOLDOWN="60"
# How long (seconds) the portal keeps a coin session alive while the NodeMCU
# is unreachable mid-insert before finally giving up. During this window the
# poll reports "reconnecting" (coins preserved, countdown frozen) instead of
# expiring. Keep this equal to the firmware's MAX_PAUSE_MS (5 min = 300s) so
# both sides abandon a truly dead link at roughly the same time.
COIN_RECONNECT_GRACE="300"

# ── Time sync ─────────────────────────────────────────────
NTP_SERVERS="pool.ntp.org time.google.com time.cloudflare.com"
