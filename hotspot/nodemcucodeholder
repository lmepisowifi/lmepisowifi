// coin_nodemcu.ino — Piso Wifi Coin Slot Controller
// ESP8266 NodeMCU
//
// FIRST BOOT (no saved config):
//   → Starts open AP "PisoWifi-Setup"
//   → Connect to it, browse to 192.168.4.1
//   → Fill in WiFi network, PSK, coin settings, hit Save
//   → Reboots and connects to your hotspot network as STA
//
// FACTORY RESET (hardware):
//   → Wire a momentary button between D1 (GPIO5) and GND
//   → Hold it during power-on for 3+ seconds
//
// FACTORY RESET (software, no extra hardware):
//   → From the portal machine, curl or wget:
//      http://<nodemcu-ip>:8080/reset
//   → Only accepts connections from PORTAL_IP (set in config)

#include <ESP8266WiFi.h>
#include <ESP8266WebServer.h>
#include <ESP8266HTTPClient.h>
#include <WiFiClient.h>
#include <MD5Builder.h>
#include <LittleFS.h>

// ── PIN DEFINITIONS ───────────────────────────────────────────────────
const int COIN_PIN        = D6;  // GPIO12  pulse input from coin acceptor
const int COIN_ENABLE_PIN = D7;  // GPIO13  inhibit line
const int RESET_PIN       = D1;  // GPIO5   external button to GND → hold 3s on boot

// Most PH coin acceptors: HIGH=accept, LOW=block. Flip if yours is inverted.
const int COIN_ENABLE_ACTIVE = HIGH;

// ── COMPILE-TIME DEFAULTS (all overridden by saved config) ────────────
#define DEFAULT_PSK         "ReplaceWithSomethingLongAndRandom!"
#define DEFAULT_PORTAL_IP   "10.0.0.1"
#define DEFAULT_PORTAL_PORT 80
#define DEFAULT_COIN_VALUE  1     // pesos per pulse
#define DEFAULT_TIMEOUT     30    // coin session seconds
#define CONFIG_PATH         "/cfg.txt"
#define AP_SSID             "PisoWifi-Setup"

// Firmware version — bump ONLY when THIS sketch actually changes. The portal's
// ota.sh compares it against the release manifest's nodemcu_version and pushes a
// self-flash ONLY when they differ, so a portal-only update (www2/hotspot files)
// never needlessly reflashes the coin slot.
#define FW_VERSION          "1.0.9"
// No AP password — open so owner can connect immediately on first setup

// ── CONFIG STRUCT ─────────────────────────────────────────────────────
struct Config {
    char     ssid[64];
    char     pass[64];
    char     psk[128];
    char     portal_ip[16];
    uint16_t portal_port;
    uint8_t  coin_value;    // pesos per pulse
    uint8_t  timeout_sec;   // coin session timeout
};
Config cfg;

